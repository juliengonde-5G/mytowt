# ═══════════════════════════════════════════════════════
# my_TOWT — Environment Configuration
# Copy this file to .env and adjust values
# ═══════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────
APP_ENV=production
DEBUG=false

# ─── Database (PostgreSQL) ────────────────────────────
POSTGRES_USER=towt_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=towt_planning

# Constructed automatically in docker-compose, but can be overridden:
# DATABASE_URL=postgresql+asyncpg://towt_admin:password@db:5432/towt_planning

# ─── Security ─────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_64_char_hex_string

# ─── Domain & SSL (production) ────────────────────────
DOMAIN=towt.example.com
CERTBOT_EMAIL=admin@example.com

# ─── Backup ───────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
