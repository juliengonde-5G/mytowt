# ═══ my_TOWT — Environment Configuration ═══
# Copy to .env and adjust values

# Application
APP_NAME=TOWT Planning
APP_VERSION=2.0.0
APP_ENV=production
DEBUG=false

# Database (PostgreSQL)
# PRODUCTION: replace CHANGE-ME with `openssl rand -hex 24`.
# The app refuses to start in production if POSTGRES_PASSWORD stays "towt_secure_2025".
DATABASE_URL=postgresql+asyncpg://towt_admin:CHANGE-ME@db:5432/towt_planning
POSTGRES_USER=towt_admin
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=towt_planning

# Security — REQUIRED, no code default. Must be >=32 chars.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# The app refuses to start in production if SECRET_KEY stays at its default.
SECRET_KEY=change-me-to-a-random-64-char-string

# Tracking API (inbound).
# Clients (Power Automate) must send this value in the X-API-Token header when
# POSTing to /api/tracking/upload. Rotate quarterly. Generate: openssl rand -hex 24.
# Leave empty to keep the endpoint closed — any request to /upload then returns 503.
TRACKING_API_TOKEN=

# Passengers module (post-liquidation: disabled by default).
# Set to true only if a successor reactivates passenger operations.
PASSENGERS_ENABLED=false

# Domain & SSL (production, optional)
DOMAIN=towt.example.com
CERTBOT_EMAIL=admin@example.com

# Pipedrive CRM integration
# Get your API token from: Pipedrive > Settings > Personal preferences > API
PIPEDRIVE_API_TOKEN=

# Backup
BACKUP_RETENTION_DAYS=30
